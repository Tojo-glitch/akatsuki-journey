import React, { useEffect, useState } from 'react'
import {
  AreaChart, Area, LineChart, Line, BarChart, Bar, Cell,
  XAxis, YAxis, Tooltip, ResponsiveContainer, ReferenceLine, Legend
} from 'recharts'
import { getEquityDrawdown, getTagAnalysis, getByDayOfWeek, getByHour } from '../lib/api'
import { Empty } from '../components/UI'

const GREEN='#26D9A0', RED='#FF5C7A', YELLOW='#FFC857', BLUE='#5B9FFF', PURPLE='#9D7FE8'
const CHART_STYLE = { background:'#12161F', border:'1px solid #222A38', borderRadius:8, fontSize:12 }
const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat']

function Section({ title, icon, children, loading }) {
  return (
    <div className="card" style={{ marginBottom:14 }}>
      <div className="card-header">
        <span className="section-title">{icon} {title}</span>
      </div>
      {loading
        ? <div className="skeleton" style={{ height:160, borderRadius:8 }} />
        : children}
    </div>
  )
}

export default function Analysis({ toast }) {
  const [equity,  setEquity]  = useState([])
  const [tags,    setTags]    = useState([])
  const [dow,     setDow]     = useState([])
  const [hourly,  setHourly]  = useState([])
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    Promise.all([
      getEquityDrawdown(),
      getTagAnalysis(),
      getByDayOfWeek(),
      getByHour(),
    ]).then(([eq, tg, d, h]) => {
      setEquity(eq); setTags(tg); setDow(d); setHourly(h)
      setLoading(false)
    }).catch(() => setLoading(false))
  }, [])

  // ── Derived stats ─────────────────────────────────────────────
  const lastEquity = equity.length ? equity[equity.length - 1] : null
  const minDrawdown = equity.length ? Math.min(...equity.map(e => e.drawdown)) : 0
  const maxEquity   = equity.length ? Math.max(...equity.map(e => e.equity))   : 0

  // Day of week full array
  const dowFull = DAYS.map((d, i) => {
    const found = dow.find(x => x.dow === i)
    return { day: d, win_rate: parseFloat(found?.win_rate)||0, win: found?.win||0, loss: found?.loss||0, total: found?.total||0 }
  })

  // Best hour window (consecutive 2-hour window with most wins)
  const bestHour = hourly.length
    ? hourly.reduce((best, h) => parseFloat(h.win_rate) > parseFloat(best?.win_rate||0) ? h : best, hourly[0])
    : null

  // Drawdown stats
  const inDrawdown = lastEquity && lastEquity.drawdown < 0
  const ddPct = maxEquity > 0 ? Math.abs(minDrawdown / maxEquity * 100).toFixed(1) : 0

  return (
    <div>
      <div className="page-title">Analysis</div>
      <div className="page-sub">Deep performance insights — all pairs combined</div>

      {/* Quick insight cards */}
      <div className="stats-row" style={{ marginBottom:14 }}>
        <div className={`stat-card ${inDrawdown ? 'red' : 'green'}`}>
          <div className="stat-label">Current Drawdown</div>
          <div className="stat-value" style={{ color: inDrawdown ? RED : GREEN }}>
            {lastEquity ? lastEquity.drawdown + 'R' : '—'}
          </div>
          <div className="stat-sub">{inDrawdown ? 'Below peak' : 'At/above peak'}</div>
        </div>
        <div className="stat-card red">
          <div className="stat-label">Max Drawdown</div>
          <div className="stat-value red">{equity.length ? minDrawdown + 'R' : '—'}</div>
          <div className="stat-sub">{ddPct}% from peak</div>
        </div>
        <div className="stat-card blue">
          <div className="stat-label">Best Hour</div>
          <div className="stat-value blue" style={{ fontSize:22 }}>
            {bestHour ? `${String(bestHour.hour).padStart(2,'0')}:00` : '—'}
          </div>
          <div className="stat-sub">{bestHour ? `${bestHour.win_rate}% WR (${bestHour.win}W/${bestHour.loss}L)` : 'No data'}</div>
        </div>
        <div className="stat-card purple">
          <div className="stat-label">Best Day</div>
          <div className="stat-value purple" style={{ fontSize:22 }}>
            {dowFull.filter(d=>d.total>0).sort((a,b)=>b.win_rate-a.win_rate)[0]?.day || '—'}
          </div>
          <div className="stat-sub">
            {(() => { const b = dowFull.filter(d=>d.total>0).sort((a,b)=>b.win_rate-a.win_rate)[0]; return b ? `${b.win_rate}% WR` : '' })()}
          </div>
        </div>
      </div>

      {/* Equity + Drawdown dual chart */}
      <Section title="Equity & Drawdown Curve" icon="📈" loading={loading}>
        {equity.length < 2 ? <Empty text="Need at least 2 closed trades to show curve" /> : (
          <>
            {/* Equity */}
            <div style={{ marginBottom:4 }}>
              <div style={{ fontSize:11, color:'var(--t2)', marginBottom:4 }}>EQUITY (R)</div>
              <ResponsiveContainer width="100%" height={140}>
                <AreaChart data={equity} margin={{ top:4, right:4, left:-24, bottom:0 }}>
                  <defs>
                    <linearGradient id="eqGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stopColor={GREEN} stopOpacity={.2}/>
                      <stop offset="100%" stopColor={GREEN} stopOpacity={0}/>
                    </linearGradient>
                  </defs>
                  <XAxis dataKey="x" hide />
                  <YAxis tick={{ fontSize:10, fill:'#7B8299' }} />
                  <Tooltip contentStyle={CHART_STYLE}
                    formatter={(v,n,p) => [`${v}R`, p.payload.pair ? p.payload.pair : 'Equity']}
                    labelFormatter={(_,p) => p[0]?.payload?.trade_date || ''} />
                  <ReferenceLine y={0} stroke="var(--border)" strokeDasharray="3 3" />
                  <Area dataKey="equity" stroke={GREEN} strokeWidth={2} fill="url(#eqGrad)" dot={false} />
                </AreaChart>
              </ResponsiveContainer>
            </div>

            {/* Drawdown */}
            <div>
              <div style={{ fontSize:11, color:'var(--t2)', marginBottom:4 }}>DRAWDOWN FROM PEAK (R)</div>
              <ResponsiveContainer width="100%" height={100}>
                <AreaChart data={equity} margin={{ top:4, right:4, left:-24, bottom:0 }}>
                  <defs>
                    <linearGradient id="ddGrad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stopColor={RED} stopOpacity={0}/>
                      <stop offset="100%" stopColor={RED} stopOpacity={.3}/>
                    </linearGradient>
                  </defs>
                  <XAxis dataKey="x" hide />
                  <YAxis tick={{ fontSize:10, fill:'#7B8299' }} />
                  <Tooltip contentStyle={CHART_STYLE}
                    formatter={v => [v + 'R', 'Drawdown']}
                    labelFormatter={(_,p) => p[0]?.payload?.trade_date || ''} />
                  <ReferenceLine y={0} stroke="var(--border)" />
                  <Area dataKey="drawdown" stroke={RED} strokeWidth={1.5}
                    fill="url(#ddGrad)" dot={false} />
                </AreaChart>
              </ResponsiveContainer>
            </div>

            {/* Summary */}
            <div style={{ display:'flex', gap:16, marginTop:12, flexWrap:'wrap' }}>
              {[
                ['Peak Equity',    maxEquity + 'R',       GREEN],
                ['Current Equity', (lastEquity?.equity||0) + 'R', lastEquity?.equity>=0?GREEN:RED],
                ['Max Drawdown',   minDrawdown + 'R',     RED],
                ['DD from Peak',   ddPct + '%',           RED],
              ].map(([lbl, val, color]) => (
                <div key={lbl} style={{ textAlign:'center', minWidth:80 }}>
                  <div style={{ fontSize:10, color:'var(--t3)', textTransform:'uppercase', letterSpacing:'.06em' }}>{lbl}</div>
                  <div style={{ fontFamily:'var(--mono)', fontSize:16, fontWeight:700, color }}>{val}</div>
                </div>
              ))}
            </div>
          </>
        )}
      </Section>

      {/* Day of week */}
      <div className="g2">
        <Section title="Performance by Day of Week" icon="📅" loading={loading}>
          {dowFull.filter(d=>d.total>0).length === 0 ? <Empty text="No data yet" /> : (
            <>
              <ResponsiveContainer width="100%" height={130}>
                <BarChart data={dowFull} margin={{ top:0, right:4, left:-28, bottom:0 }}>
                  <XAxis dataKey="day" tick={{ fontSize:11, fill:'#7B8299' }} />
                  <YAxis tick={{ fontSize:10, fill:'#7B8299' }} domain={[0,100]} unit="%" />
                  <Tooltip contentStyle={CHART_STYLE}
                    formatter={(v,n,p) => [`${v}% WR · ${p.payload.win}W / ${p.payload.loss}L`, p.payload.day]} />
                  <Bar dataKey="win_rate" radius={[4,4,0,0]}>
                    {dowFull.map((d,i) => <Cell key={i} fill={d.win_rate>=50?GREEN:d.total===0?'var(--border)':RED} />)}
                  </Bar>
                </BarChart>
              </ResponsiveContainer>

              {/* Best / Worst */}
              <div style={{ display:'flex', gap:8, marginTop:10, flexWrap:'wrap' }}>
                {(() => {
                  const traded = dowFull.filter(d=>d.total>0)
                  const best  = [...traded].sort((a,b)=>b.win_rate-a.win_rate)[0]
                  const worst = [...traded].sort((a,b)=>a.win_rate-b.win_rate)[0]
                  return [
                    best  && ['🏆 Best',  best.day,  best.win_rate,  GREEN],
                    worst && worst.day !== best?.day && ['⚠️ Worst', worst.day, worst.win_rate, RED],
                  ].filter(Boolean).map(([label, day, wr, color]) => (
                    <div key={label} style={{ padding:'7px 12px', borderRadius:8, border:`1px solid ${color}33`,
                      background:`${color}0D`, fontSize:12 }}>
                      {label}: <strong style={{ color }}>{day}</strong> — {wr}% WR
                    </div>
                  ))
                })()}
              </div>
            </>
          )}
        </Section>

        {/* Hourly heatmap */}
        <Section title="Win Rate by Hour" icon="⏰" loading={loading}>
          {hourly.length === 0 ? <Empty text="Add trades with entry time to see this" /> : (
            <>
              <ResponsiveContainer width="100%" height={130}>
                <BarChart data={hourly} margin={{ top:0, right:4, left:-28, bottom:0 }}>
                  <XAxis dataKey="hour" tick={{ fontSize:10, fill:'#7B8299' }}
                    tickFormatter={h => `${String(h).padStart(2,'0')}h`} />
                  <YAxis tick={{ fontSize:10, fill:'#7B8299' }} domain={[0,100]} unit="%" />
                  <Tooltip contentStyle={CHART_STYLE}
                    formatter={(v,n,p) => [`${v}% WR · ${p.payload.win}W/${p.payload.loss}L`, `${String(p.payload.hour).padStart(2,'0')}:00`]} />
                  <Bar dataKey="win_rate" radius={[3,3,0,0]}>
                    {hourly.map((h,i) => {
                      const sess = h.hour>=1&&h.hour<8?PURPLE:h.hour>=8&&h.hour<16?BLUE:YELLOW
                      return <Cell key={i} fill={sess} opacity={parseFloat(h.win_rate)>50?1:.5} />
                    })}
                  </Bar>
                </BarChart>
              </ResponsiveContainer>

              {/* Session legend */}
              <div style={{ display:'flex', gap:12, marginTop:8, fontSize:11, flexWrap:'wrap' }}>
                {[['Asia 01-07', PURPLE], ['London 08-15', BLUE], ['New York 16-23', YELLOW]].map(([lbl,c])=>(
                  <div key={lbl} style={{ display:'flex', alignItems:'center', gap:5 }}>
                    <div style={{ width:10, height:10, borderRadius:2, background:c }} />
                    <span style={{ color:'var(--t2)' }}>{lbl}</span>
                  </div>
                ))}
              </div>

              {/* Top 3 hours */}
              {bestHour && (
                <div style={{ marginTop:10 }}>
                  <div style={{ fontSize:11, color:'var(--t3)', marginBottom:6 }}>TOP HOURS</div>
                  {[...hourly]
                    .filter(h => h.total >= 2)
                    .sort((a,b) => parseFloat(b.win_rate)-parseFloat(a.win_rate))
                    .slice(0, 3)
                    .map(h => {
                      const sess = h.hour>=1&&h.hour<8?'Asia':h.hour>=8&&h.hour<16?'London':'NY'
                      const c    = h.hour>=1&&h.hour<8?PURPLE:h.hour>=8&&h.hour<16?BLUE:YELLOW
                      return (
                        <div key={h.hour} style={{ display:'flex', alignItems:'center', gap:8, marginBottom:5, fontSize:12 }}>
                          <span style={{ fontFamily:'var(--mono)', fontWeight:700, color:c, minWidth:48 }}>
                            {String(h.hour).padStart(2,'0')}:00
                          </span>
                          <span style={{ color:c, minWidth:52, fontSize:11 }}>[{sess}]</span>
                          <div className="bar-wrap">
                            <div className="bar-fill" style={{ width:`${h.win_rate}%`, background:c }} />
                          </div>
                          <span style={{ fontFamily:'var(--mono)', fontSize:11, color:c }}>{h.win_rate}%</span>
                          <span style={{ fontSize:10, color:'var(--t3)' }}>({h.win}W/{h.loss}L)</span>
                        </div>
                      )
                    })}
                </div>
              )}
            </>
          )}
        </Section>
      </div>

      {/* Tag behavior analysis */}
      <Section title="Behavior Tag Analysis — ผลลัพธ์ตาม Tag พฤติกรรม" icon="🧠" loading={loading}>
        {tags.length === 0 ? (
          <Empty icon="🏷️" text="No behavior tags recorded yet"
            sub="Add tags when recording trades (Planned, FOMO, Revenge Trade, etc.)" />
        ) : (
          <>
            {/* Summary insight */}
            {(() => {
              const planned  = tags.find(t => t.tag?.toLowerCase().includes('planned'))
              const revenge  = tags.find(t => t.tag?.toLowerCase().includes('revenge'))
              const fomo     = tags.find(t => t.tag?.toLowerCase().includes('fomo'))
              const insights = []
              if (planned) insights.push({ msg:`"Planned" trades win ${planned.win_rate}% — your best setup`, color:GREEN })
              if (revenge && parseFloat(revenge.win_rate) < 40) insights.push({ msg:`"Revenge Trade" wins only ${revenge.win_rate}% — avoid!`, color:RED })
              if (fomo && parseFloat(fomo.win_rate) < 40) insights.push({ msg:`"FOMO" trades win ${fomo.win_rate}% — avoid!`, color:YELLOW })
              return insights.length > 0 && (
                <div style={{ display:'flex', flexWrap:'wrap', gap:8, marginBottom:14 }}>
                  {insights.map((ins,i)=>(
                    <div key={i} style={{ padding:'8px 14px', borderRadius:8,
                      border:`1px solid ${ins.color}33`, background:`${ins.color}0D`,
                      fontSize:12, color:ins.color }}>
                      💡 {ins.msg}
                    </div>
                  ))}
                </div>
              )
            })()}

            {/* Tag table */}
            <div className="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Tag</th><th>Total</th><th>Win</th><th>Loss</th>
                    <th>Miss</th><th>Win Rate</th><th>Net R</th><th>Visual</th>
                  </tr>
                </thead>
                <tbody>
                  {tags.map(t => {
                    const wr = parseFloat(t.win_rate) || 0
                    const nr = parseFloat(t.net_rr)   || 0
                    return (
                      <tr key={t.tag}>
                        <td style={{ fontWeight:600, fontSize:13 }}>
                          <span style={{ padding:'2px 8px', borderRadius:12,
                            background:'rgba(157,127,232,.1)', color:'var(--purple)',
                            border:'1px solid rgba(157,127,232,.25)', fontSize:12 }}>
                            {t.tag}
                          </span>
                        </td>
                        <td className="mono" style={{ fontSize:12 }}>{t.total}</td>
                        <td style={{ color:GREEN, fontFamily:'var(--mono)', fontSize:12 }}>{t.win}</td>
                        <td style={{ color:RED,   fontFamily:'var(--mono)', fontSize:12 }}>{t.loss}</td>
                        <td style={{ color:YELLOW,fontFamily:'var(--mono)', fontSize:12 }}>{t.miss}</td>
                        <td>
                          <span style={{ fontFamily:'var(--mono)', fontSize:13, fontWeight:700,
                            color: wr>=60?GREEN:wr>=45?YELLOW:RED }}>
                            {wr}%
                          </span>
                        </td>
                        <td style={{ fontFamily:'var(--mono)', fontSize:12,
                          color: nr>=0?GREEN:RED, fontWeight:600 }}>
                          {nr>=0?'+':''}{nr}R
                        </td>
                        <td style={{ minWidth:100 }}>
                          <div className="bar-wrap">
                            <div className="bar-fill" style={{ width:`${wr}%`,
                              background: wr>=60?GREEN:wr>=45?YELLOW:RED }} />
                          </div>
                        </td>
                      </tr>
                    )
                  })}
                </tbody>
              </table>
            </div>
          </>
        )}
      </Section>
    </div>
  )
}